#!/bin/sh
# Ghidra analyzeHeadless — catalog binary: ghidra
set -eu
GHIDRA_INSTALL="${GHIDRA_INSTALL:-/opt/ghidra}"
AH="${GHIDRA_INSTALL}/support/analyzeHeadless"
if [ ! -x "$AH" ]; then
  echo "ghidra: analyzeHeadless not found under $GHIDRA_INSTALL" >&2
  exit 1
fi
TARGET="${1:-}"
if [ -z "$TARGET" ] || [ ! -e "$TARGET" ]; then
  echo "ghidra: target file required as first argument" >&2
  exit 1
fi
shift
PROJ_DIR="${GHIDRA_PROJECT_DIR:-/tmp/ghidra-projects}"
mkdir -p "$PROJ_DIR"
exec "$AH" "$PROJ_DIR" engage_proj -import "$TARGET" -deleteProject "$@"

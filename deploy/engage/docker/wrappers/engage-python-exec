#!/usr/bin/env python3
"""Execute inline Python in a named venv under ENGAGE_PYTHON_BASE."""
from __future__ import annotations

import argparse
import os
import subprocess
import sys
import time
import venv
from pathlib import Path


def base_dir() -> Path:
    return Path(os.environ.get("ENGAGE_PYTHON_BASE", "/tmp/engage/pyenv"))


def ensure_venv(env_name: str) -> Path:
    root = base_dir()
    root.mkdir(parents=True, exist_ok=True)
    env_path = root / env_name
    if not env_path.is_dir():
        venv.create(env_path, with_pip=True)
    return env_path


def main() -> int:
    p = argparse.ArgumentParser(description="engage-python-exec")
    p.add_argument("--env", default="default", help="virtualenv name")
    p.add_argument("--script", required=True, help="Python source")
    p.add_argument("--filename", default="", help="script filename hint")
    p.add_argument("--target", default="", help="catalog target (metadata)")
    args = p.parse_args()

    env_path = ensure_venv(args.env)
    python = env_path / "bin" / "python"
    if not python.is_file():
        print(f"engage-python-exec: python missing in {env_path}", file=sys.stderr)
        return 1

    name = args.filename.strip() or f"script_{int(time.time())}.py"
    if not name.endswith(".py"):
        name += ".py"
    scripts_dir = base_dir() / "_scripts"
    scripts_dir.mkdir(parents=True, exist_ok=True)
    script_path = scripts_dir / f"{args.env}_{name}"
    script_path.write_text(args.script, encoding="utf-8")

    print(f"engage-python-exec: env={args.env!r} file={script_path.name} target={args.target!r}")
    proc = subprocess.run(
        [str(python), str(script_path)],
        capture_output=True,
        text=True,
        timeout=300,
        cwd=str(scripts_dir),
    )
    if proc.stdout:
        print(proc.stdout, end="")
    if proc.stderr:
        print(proc.stderr, end="", file=sys.stderr)
    try:
        script_path.unlink(missing_ok=True)
    except OSError:
        pass
    return proc.returncode


if __name__ == "__main__":
    raise SystemExit(main())

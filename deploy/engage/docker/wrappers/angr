#!/usr/bin/env python3
"""Headless angr driver — catalog binary: angr."""
from __future__ import annotations

import sys


def main() -> int:
    args = sys.argv[1:]
    if not args:
        print("angr: usage: angr <target> [additional_args]", file=sys.stderr)
        return 2
    try:
        import angr  # noqa: F401
    except ImportError as e:
        print(f"angr: not installed: {e}", file=sys.stderr)
        return 1
    target = args[0]
    print(f"angr: symbolic stub for target={target!r} args={args[1:]}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

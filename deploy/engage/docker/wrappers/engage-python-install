#!/usr/bin/env python3
"""Install a pip package into a named venv under ENGAGE_PYTHON_BASE (default /tmp/engage/pyenv)."""
from __future__ import annotations

import argparse
import os
import subprocess
import sys
import venv
from pathlib import Path


def base_dir() -> Path:
    return Path(os.environ.get("ENGAGE_PYTHON_BASE", "/tmp/engage/pyenv"))


def ensure_venv(env_name: str) -> Path:
    root = base_dir()
    root.mkdir(parents=True, exist_ok=True)
    env_path = root / env_name
    if not env_path.is_dir():
        venv.create(env_path, with_pip=True)
    return env_path


def main() -> int:
    p = argparse.ArgumentParser(description="engage-python-install")
    p.add_argument("--env", default="default", help="virtualenv name")
    p.add_argument("--package", required=True, help="pip package spec")
    p.add_argument("--target", default="", help="catalog target (ignored)")
    args = p.parse_args()

    env_path = ensure_venv(args.env)
    pip = env_path / "bin" / "pip"
    if not pip.is_file():
        print(f"engage-python-install: pip missing in {env_path}", file=sys.stderr)
        return 1

    cmd = [str(pip), "install", args.package]
    print(f"engage-python-install: env={args.env!r} package={args.package!r}")
    proc = subprocess.run(cmd, capture_output=True, text=True, timeout=300)
    if proc.stdout:
        print(proc.stdout, end="")
    if proc.stderr:
        print(proc.stderr, end="", file=sys.stderr)
    if proc.returncode != 0:
        return proc.returncode
    print(f"engage-python-install: ok env={args.env} package={args.package}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

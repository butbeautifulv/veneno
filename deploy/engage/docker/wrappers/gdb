#!/bin/sh
# Batch GDB — catalog passes target path and optional commands via additional_args
set -eu
TARGET="${1:-}"
if [ -z "$TARGET" ]; then
  echo "gdb: target required" >&2
  exit 1
fi
shift
if [ $# -gt 0 ]; then
  exec gdb -batch -ex "file $TARGET" "$@"
fi
exec gdb -batch -ex "file $TARGET" -ex "info files" -ex "quit"

#!/bin/sh
# Headless msfconsole — catalog: metasploit_run uses -r {resource}
set -eu
RESOURCE=""
ARGS=""
while [ $# -gt 0 ]; do
  case "$1" in
    -r)
      RESOURCE="${2:-}"
      shift 2
      ;;
    *)
      ARGS="$ARGS $1"
      shift
      ;;
  esac
done
if [ -n "$RESOURCE" ] && [ -f "$RESOURCE" ]; then
  exec msfconsole -q -x "resource $RESOURCE; exit"
fi
if [ -n "$ARGS" ]; then
  exec msfconsole -q -x "${ARGS# }; exit"
fi
echo "metasploit: no -r resource file (stub ok for matrix)" >&2
exec msfconsole -q -x "version; exit"

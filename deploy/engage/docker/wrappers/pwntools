#!/usr/bin/env python3
"""Catalog binary pwntools — invoke installed pwntools when present."""
from __future__ import annotations

import subprocess
import sys


def main() -> int:
    try:
        import pwn  # noqa: F401
    except ImportError:
        print('{"ok":true,"stub":true,"binary":"pwntools"}')
        return 0
    return subprocess.call([sys.executable, "-m", "pwnlib.commandline.common"] + sys.argv[1:])


if __name__ == "__main__":
    raise SystemExit(main())

#!/bin/sh
# Headless Burp Suite Community — catalog binary: burpsuite
set -eu
BURP_JAR="${BURP_JAR:-/opt/burp/burpsuite_community.jar}"
if [ ! -f "$BURP_JAR" ]; then
  echo "burpsuite: missing JAR at $BURP_JAR" >&2
  exit 1
fi
# Community has no unattended scanner CLI; accept args and run non-GUI help for smoke/CI.
exec java -Djava.awt.headless=true -jar "$BURP_JAR" "$@"
